    {
      "name": "Anchor Drone",
      "slot": "ability 1",
      "type": "Ability",
      "shot_type": [
        "[[File:Ability target ui.png|40x40px|sub|class=inline-icon invert-image|link=Targeted ability|Targeted ]] Targeted [[File:Swift_Step_Icon.png|40x40px|sub|class=inline-icon invert-image|link=Movement ability|Movement ]] Movement [[File:Ability-dva7.png|40x40px|sub|class=inline-icon invert-image|link=Projectile|Projectile ]] Projectile"
      ],
      "raw": {
        "hero name": "Sierra",
        "ability name": "Anchor Drone",
        "ability key": "ability 1",
        "ability type": "Ability",
        "shot type": "[[File:Ability target ui.png|40x40px|sub|class=inline-icon invert-image|link=Targeted ability|Targeted ]] <span class=\"tooltip\" title=\"Applies to selected target. Cannot miss.\">Targeted</span><br>[[File:Swift_Step_Icon.png|40x40px|sub|class=inline-icon invert-image|link=Movement ability|Movement ]] <span class=\"tooltip\" title=\"Grants a burst of movement. Disabled by abilities that apply mobility lock status.\">Movement</span><br>[[File:Ability-dva7.png|40x40px|sub|class=inline-icon invert-image|link=Projectile|Projectile ]] <span class=\"tooltip\" title=\"Has travel time.\">Projectile</span>",
        "official description": "Launch an Anchor Drone. Reactivate to launch towards it.",
        "damage": "",
        "damage falloff range": "",
        "headshot": "",
        "headshot mod": "",
        "heal": "",
        "cooldown": "12 seconds",
        "charges": "",
        "fire rate": "",
        "ammo": "",
        "reload time": "",
        "cast time": "",
        "duration": "10 seconds",
        "pspeed": "",
        "pradius": "",
        "spread": "",
        "radius": "",
        "range distance": "16 meters (deploy range)<br>19 meters (grapple)",
        "dps": "",
        "hps": "",
        "ability keywords": "active movement::deployable;;strong projectile::ignore barrier",
        "ability details": "* When the drone is deployed, Sierra gains 2 reactivation charges that can be used to grapple to the drone.\n* The cooldown begins on deployment, not on the drones destruction.\n* Grappling to the drone requires Line of Sight to it, whilst in range.\n** The grapple will break if something obstructs the path while grappling toward it.\n* The drone can be destroyed early by using the Interact key (default F on keyboard).\n* Firing the drone into environmental cliffs will instantly destroy it, using the cooldown.\n* Holding the ability button will deploy the drone and immediately grapple to it once.\n* Momentum is kept after grappling, slightly launching the hero.\n** Jumping while grappling will end the grapple early and still launch the hero.\n* <span class=\"ability-tooltip\" data-ability=\"Helix Rifle\" ><span class=\"ability-link\">[[File:Helix Rifle.png|sub|link=Sierra#Helix Rifle|40x40px |class=inline-icon invert-image]]</span>&#32;[[Sierra#Helix Rifle|Helix Rifle]]</span> and other abilities can be used whilst grappling.\n* Whilst [[Hindered]], the drone can be deployed but the grapple cannot be used.\n* The drone cannot be [[Hacked]] or [[Stunned]], but it can be destroyed."
      },
