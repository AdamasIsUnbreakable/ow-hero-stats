    {
      "name": "Satsuriku Spree",
      "slot": "ultimate",
      "type": "Ultimate Ability",
      "shot_type": [
        "[[File:Swift_Step_Icon.png|40x40px|sub|class=inline-icon invert-image|link=Movement ability|Movement ]] Movement [[File:Icon-ability.tacticalvisor.png|40x40px|sub|class=inline-icon invert-image|link=Hitscan|Hitscan ]] Hitscan"
      ],
      "raw": {
        "hero name": "Shion",
        "ability name": "Satsuriku Spree",
        "ability key": "ultimate",
        "ability type": "Ultimate Ability",
        "shot type": "[[File:Swift_Step_Icon.png|40x40px|sub|class=inline-icon invert-image|link=Movement ability|Movement ]] <span class=\"tooltip\" title=\"Grants a burst of movement. Disabled by abilities that apply mobility lock status.\">Movement</span><br>[[File:Icon-ability.tacticalvisor.png|40x40px|sub|class=inline-icon invert-image|link=Hitscan|Hitscan ]] <span class=\"tooltip\" title=\"Hits are registered without delay.\">Hitscan</span>",
        "official description": "Rush forward 3 times in a storm of gunfire.",
        "damage": "<span class=\"tooltip\" title=\"45 - 22.5 every 0.1 seconds\">180 - 90</span>",
        "damage falloff range": "",
        "headshot": "",
        "headshot mod": "",
        "heal": "",
